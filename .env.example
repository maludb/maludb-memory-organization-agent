# Copy to .env and fill in. Never commit .env.

# --- agent-api (Fastify control plane) ---
AGENT_API_PORT=3000
AGENT_API_HOST=0.0.0.0

# --- worker / queue (Redis backing BullMQ) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- operational database (agent-owned PostgreSQL; NOT a MaluDB database) ---
AGENT_DB_URL=postgres://maludb_agent:changeme@127.0.0.1:5432/maludb_agent

# --- operator auth for the control API (see docs/requirements.md SR-4) ---
AGENT_ADMIN_TOKEN=replace-with-a-strong-random-token

# --- logging ---
LOG_LEVEL=info
LOG_PRETTY=1

# --- MaluDB tenant credentials ---
# Tenant bearer tokens are NOT stored as plaintext config (see docs/decisions.md ADR-0004).
# Each tenant is registered via the control API with an api_base_url + a bearer-token
# *secret reference*; the token itself lives in your secret store / env, e.g.:
#   MALUDB_TOKEN__ACME=malu_xxxxxxxxxxxxxxxx
